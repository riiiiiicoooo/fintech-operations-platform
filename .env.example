# ============================================================================
# Fintech Operations Platform - Environment Configuration
# ============================================================================
# Copy to .env and fill in actual values
# NEVER commit .env to version control

# ============================================================================
# Database
# ============================================================================

# Supabase PostgreSQL connection
# Format: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://user:password@db.supabase.co:5432/postgres

# Database connection pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# ============================================================================
# Stripe Integration
# ============================================================================

# Stripe Live Keys (production)
STRIPE_API_KEY=sk_live_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_live_your_secret_here

# Stripe Test Keys (development - optional)
STRIPE_TEST_API_KEY=sk_test_your_key_here
STRIPE_TEST_WEBHOOK_SECRET=whsec_test_your_secret_here

# Enable/disable test mode
STRIPE_TEST_MODE=false

# ============================================================================
# Redis (for queues, caching, rate limiting)
# ============================================================================

# Redis connection
# Format: redis://:password@host:port/database
REDIS_URL=redis://localhost:6379/0

# Celery configuration (async task queue)
CELERY_BROKER_URL=$REDIS_URL
CELERY_RESULT_BACKEND=$REDIS_URL

# ============================================================================
# Trigger.dev (Job Orchestration)
# ============================================================================

# Trigger.dev API key
TRIGGER_DEV_API_KEY=tr_live_your_api_key_here

# Trigger.dev project ID
TRIGGER_DEV_PROJECT_ID=your_project_id

# Trigger.dev environment (prod, staging, dev)
TRIGGER_DEV_ENVIRONMENT=prod

# ============================================================================
# n8n (Workflow Automation)
# ============================================================================

# n8n API URL
N8N_API_URL=https://n8n.example.com/api

# n8n API key
N8N_API_KEY=your_n8n_api_key_here

# ============================================================================
# Grafana (Monitoring & Dashboards)
# ============================================================================

# Grafana API URL
GRAFANA_API_URL=https://grafana.example.com/api

# Grafana API key
GRAFANA_API_KEY=your_grafana_api_key_here

# ============================================================================
# Jira (Issue Tracking)
# ============================================================================

# Jira instance URL
JIRA_URL=https://your-domain.atlassian.net

# Jira API token (generated from https://id.atlassian.com/manage/api-tokens)
JIRA_API_TOKEN=your_jira_api_token_here

# Jira project key (e.g., FINOPS)
JIRA_PROJECT_KEY=FINOPS

# ============================================================================
# Slack (Notifications)
# ============================================================================

# Slack bot token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-your_token_here

# Slack signing secret (for webhook verification)
SLACK_SIGNING_SECRET=your_signing_secret_here

# Default Slack channels
SLACK_ALERTS_CHANNEL=payments-ops
SLACK_ERRORS_CHANNEL=errors

# ============================================================================
# Resend (Email Service)
# ============================================================================

# Resend API key for transactional emails
RESEND_API_KEY=re_your_api_key_here

# Email sender address and name
SENDER_EMAIL=noreply@fintech-ops.example.com
SENDER_NAME=Fintech Operations

# ============================================================================
# HashiCorp Vault (Secrets Management)
# ============================================================================

# Vault server address
VAULT_ADDR=https://vault.example.com

# Vault authentication token (or use role-based auth in production)
VAULT_TOKEN=your_vault_token_here

# Vault secret mount path
VAULT_SECRET_PATH=secret/fintech-ops

# ============================================================================
# Application Configuration
# ============================================================================

# Deployment environment (development, staging, production)
ENVIRONMENT=production

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# API host and port
API_HOST=0.0.0.0
API_PORT=8000

# API base URL (for webhooks, emails, etc.)
API_BASE_URL=https://api.example.com

# Frontend dashboard URL (for dashboard links in emails/alerts)
DASHBOARD_URL=https://dashboard.example.com

# Support email for user inquiries
SUPPORT_EMAIL=support@example.com

# Finance team email (for reconciliation alerts, settlement confirmations)
FINANCE_TEAM_EMAIL=finance@example.com

# Operations team email
OPS_TEAM_EMAIL=operations@example.com

# ============================================================================
# Feature Flags
# ============================================================================

# Enable/disable multi-PSP routing
MULTI_PSP_ENABLED=true

# Enable/disable real-time fraud detection
FRAUD_DETECTION_ENABLED=true

# Enable/disable automatic settlement batching
SETTLEMENT_AUTOMATION_ENABLED=true

# Enable/disable nightly reconciliation
RECONCILIATION_ENABLED=true

# Enable/disable compliance monitoring
COMPLIANCE_MONITORING_ENABLED=true

# ============================================================================
# Fraud Detection Configuration
# ============================================================================

# Fraud rule thresholds
FRAUD_VELOCITY_HOURLY_THRESHOLD=5
FRAUD_VELOCITY_DAILY_AMOUNT_THRESHOLD=2000
FRAUD_AMOUNT_MULTIPLIER_THRESHOLD=3.0
FRAUD_SCORE_REVIEW_THRESHOLD=30
FRAUD_SCORE_DECLINE_THRESHOLD=70

# ============================================================================
# Settlement Configuration
# ============================================================================

# Settlement batch processing
SETTLEMENT_CRON_SCHEDULE="0 18 * * *"  # Daily 6 PM ET
SETTLEMENT_BATCH_SIZE=5000
SETTLEMENT_TIMEOUT_MINUTES=60

# Settlement holdback percentage (0-100)
SETTLEMENT_HOLDBACK_PERCENTAGE=5

# Platform fee percentage (0-100)
PLATFORM_FEE_PERCENTAGE=2.5

# ============================================================================
# Reconciliation Configuration
# ============================================================================

# Reconciliation job schedule
RECONCILIATION_CRON_SCHEDULE="0 2 * * *"  # Daily 2 AM ET

# Reconciliation matching tolerances
RECONCILIATION_FUZZY_TOLERANCE=0.01  # 1 cent
RECONCILIATION_TIMING_TOLERANCE=1    # 1 day (T+1 settlement)

# Match rate targets
RECONCILIATION_TARGET_MATCH_RATE=0.98  # 98%
RECONCILIATION_TARGET_EXCEPTION_RATE=0.005  # 0.5%

# ============================================================================
# KYC/AML Configuration
# ============================================================================

# KYC tier limits (monthly in USD)
KYC_BASIC_LIMIT=500
KYC_STANDARD_LIMIT=5000
KYC_ENHANCED_LIMIT=999999

# Transaction monitoring
AML_VELOCITY_CHECK_ENABLED=true
AML_BEHAVIORAL_CHECK_ENABLED=true
AML_OFAC_CHECK_ENABLED=true

# SAR filing thresholds
SAR_CUMULATIVE_THRESHOLD=5000
SAR_PATTERN_THRESHOLD=10  # Number of suspicious patterns

# ============================================================================
# Bank Integration
# ============================================================================

# Bank API endpoints
BANK_API_URL=https://api.bank.example.com
BANK_API_KEY=your_bank_api_key_here

# Bank account information
BANK_ROUTING_NUMBER=021000021
BANK_ACCOUNT_NUMBER=your_account_number_here

# ============================================================================
# Observability & Monitoring
# ============================================================================

# Datadog (optional, for APM/tracing)
DATADOG_ENABLED=false
DATADOG_API_KEY=your_datadog_api_key_here
DATADOG_SITE=datadoghq.com

# Sentry (optional, for error tracking)
SENTRY_ENABLED=false
SENTRY_DSN=https://key@sentry.io/project

# ============================================================================
# Security
# ============================================================================

# JWT secret for API authentication
JWT_SECRET_KEY=your_long_random_secret_key_here

# Encryption key for PII (AES-256)
ENCRYPTION_KEY=your_32_byte_base64_encoded_key_here

# CORS allowed origins (comma-separated)
CORS_ORIGINS=https://dashboard.example.com,https://admin.example.com

# Rate limiting (requests per minute per IP)
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW_MINUTES=1

# ============================================================================
# Idempotency & Retry Logic
# ============================================================================

# Idempotency key expiration (hours)
IDEMPOTENCY_KEY_TTL=24

# Retry configuration
RETRY_MAX_ATTEMPTS=3
RETRY_INITIAL_BACKOFF_SECONDS=1
RETRY_MAX_BACKOFF_SECONDS=60
RETRY_EXPONENTIAL_BASE=2

# ============================================================================
# Testing & Development
# ============================================================================

# Test mode fixtures and seeds
PYTEST_ENABLED=true
TEST_DATABASE_URL=postgresql://test:password@localhost:5432/fintech_ops_test

# Debug mode (verbose logging, disabled in production)
DEBUG=false

# ============================================================================
# Health Check Configuration
# ============================================================================

# Health check endpoints (for Kubernetes, load balancers)
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL_SECONDS=30
HEALTH_CHECK_DATABASE=true
HEALTH_CHECK_REDIS=true
HEALTH_CHECK_STRIPE=true
